# Server Configuration
PORT=8000
HOST=127.0.0.1
DATABASE_PATH=qaricrm.db

# Simulator Settings
SIMULATOR_INTERVAL_SECONDS=40

# Google OAuth Credentials (Can also be configured in UI Settings)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/gmail/callback

# Meta Integrations (Can also be configured in UI Settings)
# META_VERIFY_TOKEN=your_custom_webhook_verify_token
# META_PAGE_ACCESS_TOKEN=your_page_access_token_for_messenger_and_instagram
# META_WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id
# META_WHATSAPP_ACCESS_TOKEN=your_whatsapp_cloud_api_token
